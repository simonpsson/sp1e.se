# Local dev secrets for Cloudflare Pages
# Copy this file to .dev.vars and fill in your values.
# .dev.vars is gitignored — never commit it.
#
# Generate AUTH_PASSWORD_HASH with:
#   node scripts/hash-password.js "your-password"
# In the Cloudflare dashboard, paste only the hash value itself.
# Do not include `AUTH_PASSWORD_HASH=` or wrapping quotes.

AUTH_PASSWORD_HASH=pbkdf2:100000:<saltHex>:<hashHex>
# Required for Mosquito admin console. No fallback to AUTH_PASSWORD_HASH.
GAME_ADMIN_PASSWORD_HASH=pbkdf2:100000:<saltHex>:<hashHex>

# Spotify integration (required for /api/spotify/* routes; OAuth callback is handled by index.html)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
# Production: https://sp1e.se/   |   Local dev: http://localhost:8788/
SPOTIFY_REDIRECT_URI=https://sp1e.se/
